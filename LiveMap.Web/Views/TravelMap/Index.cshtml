@model LiveMap.Web.Models.TravelMap.TravelMapIndexViewModel
@using System.Text.Json
@{
    ViewData["Title"] = Model.Title;
    var aliasesJson = JsonSerializer.Serialize(Model.CountryAliases);
    var paletteJson = JsonSerializer.Serialize(Model.Palette);
    var visitedJson = JsonSerializer.Serialize(Model.VisitedCountries.ToDictionary(x => x.CountryValue, x => new { colorHex = x.ColorHex, countryName = x.CountryName, folderCount = x.FolderCount, pictureCount = x.PictureCount }));
}

<section class="travel-map-shell travel-map-shell-modern">
    <div class="travel-map-hero">
        <div>
            <p class="section-eyebrow mb-2">Your private travel progress</p>
            <h1 class="hero-title mb-2">@Model.Title</h1>
            <p class="hero-subtitle mb-0">
                Every folder with a country name and at least one uploaded image lights up on your personal map.
                Default color is yellow, and you can repaint each unlocked country from the palette above the map.
            </p>
        </div>
        <div class="travel-map-counter-card">
            <span class="travel-map-counter-value">@Model.VisitedCountries.Count</span>
            <span class="travel-map-counter-label">colored countries</span>
        </div>
    </div>

    @Html.AntiForgeryToken()

    <div class="travel-map-grid">
        <div class="travel-map-panel">
            <div class="travel-map-panel-header">
                <div>
                    <p class="section-eyebrow mb-1">Palette</p>
                    <h2 class="section-title mb-0">Choose your stamp color</h2>
                </div>
                <span class="map-badge">10 colors</span>
            </div>

            <div class="travel-color-palette" id="travelColorPalette">
                @for (var i = 0; i < Model.Palette.Count; i++)
                {
                    var color = Model.Palette[i];
                    <button type="button"
                            class="travel-color-swatch @(i == 0 ? "is-active" : string.Empty)"
                            data-color="@color"
                            style="background-color:@color"
                            aria-label="Select @color color"></button>
                }
            </div>

            <div class="travel-map-board">
                <div id="passportPaletteMap" class="world-map passport-palette-map" aria-label="Personal visited countries map"></div>
            </div>

            <p class="travel-map-hint mb-0">Tip: pick a color, then click an already unlocked country on the map or in the list below.</p>
        </div>

        <aside class="travel-map-sidebar">
            <div class="travel-map-panel-header">
                <div>
                    <p class="section-eyebrow mb-1">Unlocked countries</p>
                    <h2 class="section-title mb-0">Your folder stamps</h2>
                </div>
            </div>

            @if (Model.VisitedCountries.Any())
            {
                <div class="travel-country-list" id="travelCountryList">
                    @foreach (var country in Model.VisitedCountries)
                    {
                        <button type="button"
                                class="travel-country-chip"
                                data-country="@country.CountryValue">
                            <span class="travel-country-chip-color" style="background-color:@country.ColorHex"></span>
                            <span class="travel-country-chip-text">
                                <strong>@country.CountryName</strong>
                                <small>@country.FolderCount folder(s) · @country.PictureCount image(s)</small>
                            </span>
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="empty-state-card">
                    <h3>No countries unlocked yet</h3>
                    <p class="mb-0">Create a folder with a country name like Italy, upload at least one picture inside it, and the country will appear here automatically.</p>
                </div>
            }
        </aside>
    </div>
</section>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>

    <script>
        const travelMapCountryAliases = @Html.Raw(aliasesJson);
        const travelMapPalette = @Html.Raw(paletteJson);
        const visitedCountries = @Html.Raw(visitedJson);
        const defaultVisitedColor = '@Model.DefaultColor';
        const saveColorUrl = '@Url.Action("SaveColor", "TravelMap")';
        const antiforgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

        (() => {
            const paletteButtons = Array.from(document.querySelectorAll('.travel-color-swatch'));
            const countryChips = Array.from(document.querySelectorAll('.travel-country-chip'));
            let activeColor = paletteButtons.find(x => x.classList.contains('is-active'))?.dataset.color || defaultVisitedColor;
            const layerRegistry = {};

            const normalizeKey = (value) => value
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/[^a-zA-Z0-9]/g, '')
                .toLowerCase();

            const setActiveColor = (color) => {
                activeColor = color;
                paletteButtons.forEach(button => button.classList.toggle('is-active', button.dataset.color === color));
            };

            const paintCountryUi = (countryValue, color) => {
                const layer = layerRegistry[countryValue];
                if (layer) {
                    layer.setStyle({ fillColor: color, fillOpacity: 0.85, color: '#0f172a', weight: 1.1 });
                }

                const chip = document.querySelector(`.travel-country-chip[data-country="${countryValue}"]`);
                const chipColor = chip?.querySelector('.travel-country-chip-color');
                if (chipColor) {
                    chipColor.style.backgroundColor = color;
                }

                if (visitedCountries[countryValue]) {
                    visitedCountries[countryValue].colorHex = color;
                }
            };

            const saveColor = async (countryValue) => {
                const response = await fetch(saveColorUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': antiforgeryToken
                    },
                    body: JSON.stringify({ country: countryValue, colorHex: activeColor })
                });

                if (!response.ok) {
                    throw new Error('Could not save color.');
                }

                paintCountryUi(countryValue, activeColor);
            };

            paletteButtons.forEach(button => {
                button.addEventListener('click', () => setActiveColor(button.dataset.color));
            });

            countryChips.forEach(chip => {
                chip.addEventListener('click', async () => {
                    try {
                        await saveColor(chip.dataset.country);
                    } catch {
                        alert('Color could not be saved right now.');
                    }
                });
            });

            const map = L.map('passportPaletteMap', {
                worldCopyJump: true,
                minZoom: 1.3,
                maxZoom: 6,
                zoomSnap: 0.1,
                attributionControl: true
            }).setView([20, 0], 1.5);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 6,
                minZoom: 1,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            const lockedStyle = {
                color: '#0f172a',
                weight: 0.9,
                fillColor: '#ffffff',
                fillOpacity: 0.92
            };

            const unlockedStyle = (countryValue) => ({
                color: '#0f172a',
                weight: 1.1,
                fillColor: visitedCountries[countryValue]?.colorHex || defaultVisitedColor,
                fillOpacity: 0.85
            });

            fetch('https://cdn.jsdelivr.net/gh/datasets/geo-countries@master/data/countries.geojson')
                .then(response => response.json())
                .then(geoJson => {
                    const geoLayer = L.geoJSON(geoJson, {
                        style: (feature) => {
                            const rawName = feature?.properties?.ADMIN || feature?.properties?.name || feature?.properties?.name_long;
                            const countryValue = rawName ? travelMapCountryAliases[normalizeKey(rawName)] : null;
                            return countryValue && visitedCountries[countryValue]
                                ? unlockedStyle(countryValue)
                                : lockedStyle;
                        },
                        onEachFeature: (feature, layer) => {
                            const rawName = feature?.properties?.ADMIN || feature?.properties?.name || feature?.properties?.name_long;
                            if (!rawName) {
                                return;
                            }

                            const countryValue = travelMapCountryAliases[normalizeKey(rawName)];
                            if (countryValue && visitedCountries[countryValue]) {
                                layerRegistry[countryValue] = layer;
                                layer.bindTooltip(`${visitedCountries[countryValue].countryName} · click to recolor`, { sticky: true });
                                layer.on('mouseover', () => layer.setStyle({ weight: 2 }));
                                layer.on('mouseout', () => paintCountryUi(countryValue, visitedCountries[countryValue].colorHex || defaultVisitedColor));
                                layer.on('click', async () => {
                                    try {
                                        await saveColor(countryValue);
                                    } catch {
                                        alert('Color could not be saved right now.');
                                    }
                                });
                            } else {
                                layer.bindTooltip(`${rawName} · locked`, { sticky: true });
                            }
                        }
                    }).addTo(map);

                    map.fitBounds(geoLayer.getBounds(), { padding: [10, 10] });
                })
                .catch(() => {
                    const fallback = document.createElement('p');
                    fallback.className = 'map-fallback';
                    fallback.textContent = 'The map could not be loaded right now.';
                    document.getElementById('passportPaletteMap').appendChild(fallback);
                });
        })();
    </script>
}
