@model LiveMap.Web.Models.Home.HomeIndexViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Explore countries";
    var aliasesJson = JsonSerializer.Serialize(Model.CountryAliases);
}

<section class="home-page">
    <div class="home-hero">
        <div class="home-hero-copy">
            <p class="home-kicker">Discover public travel folders</p>

            <h1 class="home-title">Search by country or click the world map</h1>

            <p class="home-description">
                Pick a country from the search dropdown or click it on the map to open all images from public folders for that country.
                Selecting an image takes visitors to the creator's profile.
            </p>

            <form asp-controller="Home" asp-action="Country" method="get" class="country-search-panel" id="countrySearchForm">
                <div class="country-combobox" id="countryCombobox">
                    <input type="hidden" name="country" id="selectedCountryValue" />

                    <label class="form-label home-label" for="countrySearchInput">Country</label>

                    <div class="country-combobox-input-wrap">
                        <input id="countrySearchInput"
                               type="text"
                               class="form-control country-search-input"
                               placeholder="Search for Bulgaria, France, Japan..."
                               autocomplete="off"
                               aria-expanded="false"
                               aria-controls="countryOptionsList"
                               aria-autocomplete="list" />
                        <button type="button" class="country-combobox-toggle" id="countryComboboxToggle" aria-label="Toggle country list">⌄</button>
                    </div>

                    <div class="country-options" id="countryOptionsList" role="listbox">
                        @foreach (var country in Model.Countries)
                        {
                            <button type="button"
                                    class="country-option"
                                    data-value="@country.Value"
                                    data-name="@country.Name"
                                    role="option">
                                <span class="country-option-flag" aria-hidden="true">@country.FlagEmoji</span>
                                <span class="country-option-name">@country.Name</span>
                            </button>
                        }
                    </div>
                </div>

                <button type="submit" class="btn home-search-button">Open country gallery</button>
            </form>
        </div>

        <div class="home-map-panel">
            <div class="home-map-topbar">
                <div>
                    <p class="home-map-kicker">Interactive world map</p>
                    <h2 class="home-map-title">Click any country</h2>
                </div>

                <span class="home-map-chip">World view</span>
            </div>

            <div id="worldMap" class="world-map" aria-label="Interactive world map"></div>
        </div>
    </div>
</section>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>

    <script>
        const countryAliases = @Html.Raw(aliasesJson);

        (() => {
            const form = document.getElementById('countrySearchForm');
            const combobox = document.getElementById('countryCombobox');
            const input = document.getElementById('countrySearchInput');
            const hidden = document.getElementById('selectedCountryValue');
            const list = document.getElementById('countryOptionsList');
            const toggle = document.getElementById('countryComboboxToggle');
            const options = Array.from(list.querySelectorAll('.country-option'));

            const openList = () => {
                combobox.classList.add('is-open');
                input.setAttribute('aria-expanded', 'true');
            };

            const closeList = () => {
                combobox.classList.remove('is-open');
                input.setAttribute('aria-expanded', 'false');
            };

            const selectOption = (button) => {
                hidden.value = button.dataset.value;
                input.value = button.dataset.name;
                options.forEach(option => option.classList.toggle('is-selected', option === button));
                closeList();
            };

            const filterOptions = () => {
                const term = input.value.trim().toLowerCase();
                options.forEach(option => {
                    const label = option.dataset.name.toLowerCase();
                    option.hidden = term.length > 0 && !label.includes(term);
                });
            };

            toggle.addEventListener('click', () => {
                combobox.classList.contains('is-open') ? closeList() : openList();
            });

            input.addEventListener('focus', openList);
            input.addEventListener('input', () => {
                hidden.value = '';
                filterOptions();
                openList();
            });

            options.forEach(option => {
                option.addEventListener('click', () => selectOption(option));
            });

            document.addEventListener('click', (event) => {
                if (!combobox.contains(event.target)) {
                    closeList();
                }
            });

            form.addEventListener('submit', (event) => {
                if (!hidden.value) {
                    const normalizedInput = input.value
                        .normalize('NFD')
                        .replace(/[\u0300-\u036f]/g, '')
                        .replace(/[^a-zA-Z0-9]/g, '')
                        .toLowerCase();

                    const matchedValue = countryAliases[normalizedInput];
                    if (matchedValue) {
                        hidden.value = matchedValue;
                    }
                }

                if (!hidden.value) {
                    event.preventDefault();
                    input.focus();
                }
            });
        })();

        (() => {
            const initialCoordinates = [20, 0];
            const map = L.map('worldMap', {
                worldCopyJump: true,
                minZoom: 1.3,
                maxZoom: 6,
                zoomSnap: 0.1,
                attributionControl: true
            }).setView(initialCoordinates, 1.5);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 6,
                minZoom: 1,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

        const defaultStyle = {
            color: '#6367FF',
            weight: 1,
            fillColor: '#C9BEFF',
            fillOpacity: 0.30
        };

        const hoverStyle = {
            color: '#6367FF',
            weight: 1.7,
            fillColor: '#8494FF',
            fillOpacity: 0.45
        };

            const normalizeKey = (value) => value
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/[^a-zA-Z0-9]/g, '')
                .toLowerCase();

            fetch('https://cdn.jsdelivr.net/gh/datasets/geo-countries@master/data/countries.geojson')
                .then(response => response.json())
                .then(geoJson => {
                    const geoLayer = L.geoJSON(geoJson, {
                        style: defaultStyle,
                        onEachFeature: (feature, layer) => {
                            const rawName = feature?.properties?.ADMIN || feature?.properties?.name || feature?.properties?.name_long;
                            if (!rawName) {
                                return;
                            }

                            layer.bindTooltip(rawName, { sticky: true });

                            layer.on('mouseover', () => layer.setStyle(hoverStyle));
                            layer.on('mouseout', () => geoLayer.resetStyle(layer));
                            layer.on('click', () => {
                                const normalized = normalizeKey(rawName);
                                const matchedCountry = countryAliases[normalized];
                                if (matchedCountry) {
                                    window.location.href = '@Url.Action("Country", "Home")?country=' + encodeURIComponent(matchedCountry);
                                }
                            });
                        }
                    }).addTo(map);

                    map.fitBounds(geoLayer.getBounds(), { padding: [10, 10] });
                })
                .catch(() => {
                    const fallback = document.createElement('p');
                    fallback.className = 'map-fallback';
                    fallback.textContent = 'The map could not be loaded right now. Use the country dropdown above.';
                    document.getElementById('worldMap').appendChild(fallback);
                });
        })();
    </script>
}
