@model LiveMap.Web.Models.Home.ExploreFeedViewModel
@using LiveMap.Web.Models.Home
@{
    ViewData["Title"] = "Explore";

    var isNewest = Model.SelectedFilter == ExploreFilterOptions.Newest;
    var isOldest = Model.SelectedFilter == ExploreFilterOptions.Oldest;
    var isByUser = Model.SelectedFilter == ExploreFilterOptions.ByUser;
    var isPopular = Model.SelectedFilter == ExploreFilterOptions.PopularUsers;
    var isFollowing = Model.SelectedFilter == ExploreFilterOptions.FollowingNewest;
    var isFriends = Model.SelectedFilter == ExploreFilterOptions.FriendsNewest;
}

<section class="explore-showcase">
    <div class="explore-showcase-copy">
        <p class="section-eyebrow">Explore the vibe</p>
        <h1 class="section-title explore-showcase-title">Discover travel stories with a more editorial, social and premium feel.</h1>
        <p class="explore-showcase-text">Jump between fresh uploads, creator-focused filters and public memories from around the world. Same functionality, just way more presence.</p>

        <div class="explore-mood-row">
            <div class="explore-mood-card is-primary">
                <span class="explore-mood-label">Results</span>
                <strong>@Model.ResultsCount</strong>
                <small>public moments right now</small>
            </div>
            <div class="explore-mood-card">
                <span class="explore-mood-label">Mode</span>
                <strong>@Model.Heading</strong>
                <small>switch the feed in one click</small>
            </div>
        </div>
    </div>

    <div class="explore-showcase-panel">
        <div class="explore-floating-pill">Live public feed</div>
        <div class="explore-panel-grid">
            <div class="explore-panel-card">
                <span>Fresh uploads</span>
                <strong>Magazine look</strong>
            </div>
            <div class="explore-panel-card is-soft">
                <span>Creators</span>
                <strong>Faces + folders</strong>
            </div>
            <div class="explore-panel-card is-wide">
                <span>Interactions</span>
                <strong>Like, comment and open profiles directly from the feed.</strong>
            </div>
        </div>
        <div class="explore-orb one"></div>
        <div class="explore-orb two"></div>
    </div>
</section>

<section class="explore-command-card mb-4">
    <div class="explore-command-topbar">
        <div>
            <p class="section-eyebrow mb-1">Feed controls</p>
            <h2 class="section-title mb-0">Curate the exact mood of the feed</h2>
        </div>
        <div class="explore-filter-hint-inline">
            <span class="badge rounded-pill text-bg-light">@Model.ResultsCount posts</span>
            <span>@Model.Description</span>
        </div>
    </div>

    <div class="explore-filter-chip-row" role="tablist" aria-label="Quick explore filters">
        <button type="button" class="explore-chip @(isNewest ? "is-active" : "")" data-filter-value="@ExploreFilterOptions.Newest">Newest</button>
        <button type="button" class="explore-chip @(isOldest ? "is-active" : "")" data-filter-value="@ExploreFilterOptions.Oldest">Oldest</button>
        <button type="button" class="explore-chip @(isByUser ? "is-active" : "")" data-filter-value="@ExploreFilterOptions.ByUser">By user</button>
        <button type="button" class="explore-chip @(isPopular ? "is-active" : "")" data-filter-value="@ExploreFilterOptions.PopularUsers">Popular users</button>
        <button type="button" class="explore-chip @(isFollowing ? "is-active" : "")" data-filter-value="@ExploreFilterOptions.FollowingNewest">Following</button>
        <button type="button" class="explore-chip @(isFriends ? "is-active" : "")" data-filter-value="@ExploreFilterOptions.FriendsNewest">Friends</button>
    </div>

    <form method="get" asp-controller="Home" asp-action="Explore" class="explore-command-form">
        <div class="explore-command-main">
            <div>
                <label for="filter" class="form-label fw-semibold">Feed type</label>
                <select id="filter" name="filter" class="form-select explore-filter-select">
                    @if (isNewest) { <option value="@ExploreFilterOptions.Newest" selected>Newest public pictures</option> } else { <option value="@ExploreFilterOptions.Newest">Newest public pictures</option> }
                    @if (isOldest) { <option value="@ExploreFilterOptions.Oldest" selected>Oldest public pictures</option> } else { <option value="@ExploreFilterOptions.Oldest">Oldest public pictures</option> }
                    @if (isByUser) { <option value="@ExploreFilterOptions.ByUser" selected>Pictures by username</option> } else { <option value="@ExploreFilterOptions.ByUser">Pictures by username</option> }
                    @if (isPopular) { <option value="@ExploreFilterOptions.PopularUsers" selected>Pictures from most popular users</option> } else { <option value="@ExploreFilterOptions.PopularUsers">Pictures from most popular users</option> }
                    @if (isFollowing) { <option value="@ExploreFilterOptions.FollowingNewest" selected>Newest pictures from people I follow</option> } else { <option value="@ExploreFilterOptions.FollowingNewest">Newest pictures from people I follow</option> }
                    @if (isFriends) { <option value="@ExploreFilterOptions.FriendsNewest" selected>Newest pictures from my friends</option> } else { <option value="@ExploreFilterOptions.FriendsNewest">Newest pictures from my friends</option> }
                </select>
            </div>

            <div id="usernameContainer" style="@(isByUser ? "display:block;" : "display:none;")">
                <label for="username" class="form-label fw-semibold">Username</label>
                <input id="username" name="username" class="form-control" value="@Model.UsernameQuery" placeholder="Search by username..." />
            </div>

            <div class="explore-command-action">
                <button type="submit" class="btn btn-primary w-100">Apply feed</button>
            </div>
        </div>
    </form>
</section>

@if (Model.RequiresLoginNotice)
{
    <div class="alert alert-warning">To use this filter, first sign in to your account.</div>
}

@if (Model.SelectedFilter == ExploreFilterOptions.ByUser && string.IsNullOrWhiteSpace(Model.UsernameQuery))
{
    <div class="alert alert-info">Type a username above and press Apply to see that user's public pictures.</div>
}
else if (Model.Pictures.Any())
{
    <section class="explore-feed-grid">
        @foreach (var picture in Model.Pictures)
        {
            <article class="explore-spotlight-card">
                <div class="explore-spotlight-media-wrap">
                    <img src="@picture.ImageUrl" class="explore-spotlight-media" alt="@picture.FolderName image" loading="lazy" referrerpolicy="no-referrer" onerror="this.onerror=null;this.src='/images/travel-placeholder.jpg';" />
                    <div class="explore-spotlight-overlay">
                        <span class="explore-overlay-pill">@picture.FolderName</span>
                        <span class="explore-overlay-pill is-ghost">@picture.CreatedOn.ToLocalTime().ToString("dd MMM yyyy")</span>
                    </div>
                </div>

                <div class="explore-spotlight-body">
                    <div class="explore-creator-row">
                        <div class="explore-creator-main">
                            <img src="@(string.IsNullOrWhiteSpace(picture.ProfilePicture) ? "/images/default.jpeg" : picture.ProfilePicture)"
                                 alt="@picture.Username avatar"
                                 class="explore-creator-avatar" />
                            <div>
                                <div class="explore-creator-name">@picture.Username</div>
                                <div class="explore-creator-meta">♥ @picture.LikesCount · 💬 @picture.CommentsCount@if (isPopular) {<text> · Followers: @picture.FollowersCount</text>}</div>
                            </div>
                        </div>
                        <a asp-controller="Profile" asp-action="Details" asp-route-id="@picture.ProfileId" class="explore-mini-link">Profile</a>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(picture.Description))
                    {
                        <p class="explore-spotlight-description">@picture.Description</p>
                    }
                    else
                    {
                        <p class="explore-spotlight-description is-muted">A clean travel memory from @picture.Username's public folder collection.</p>
                    }

                    @if (picture.CanInteract)
                    {
                        <div class="explore-action-strip">
                            <form asp-controller="Picture" asp-action="ToggleLike" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@picture.PictureId" />
                                <input type="hidden" name="folderId" value="@picture.FolderId" />
                                <button type="submit" class="explore-icon-button @(picture.IsLikedByCurrentUser ? "is-liked" : "")">♥ <span>@(picture.IsLikedByCurrentUser ? "Liked" : "Like")</span></button>
                            </form>
                            <a class="explore-icon-button is-secondary" href="#explore-comments-@picture.PictureId">💬 <span>Comment</span></a>
                            <a asp-controller="Folder" asp-action="Details" asp-route-id="@picture.FolderId" class="explore-icon-button is-secondary">↗ <span>Open folder</span></a>
                        </div>

                        <form asp-controller="Picture" asp-action="AddComment" method="post" class="explore-comment-form" id="explore-comments-@picture.PictureId">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@picture.PictureId" />
                            <input type="hidden" name="folderId" value="@picture.FolderId" />
                            <input type="text" name="content" class="form-control" maxlength="500" placeholder="Drop a quick comment..." />
                            <button type="submit" class="btn btn-outline-primary">Post</button>
                        </form>
                    }

                    @if (picture.Comments.Any())
                    {
                        <div class="explore-comment-stack">
                            @foreach (var comment in picture.Comments)
                            {
                                <div class="explore-comment-bubble">
                                    <strong>@comment.Username</strong>
                                    <span>@comment.Content</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </article>
        }
    </section>
}
else
{
    <div class="alert alert-info">No pictures matched this filter yet.</div>
}

@section Scripts {
    <script>
        (() => {
            const filterSelect = document.getElementById("filter");
            const usernameContainer = document.getElementById("usernameContainer");
            const chips = document.querySelectorAll(".explore-chip");

            function toggleUsernameField() {
                if (!filterSelect || !usernameContainer) return;
                usernameContainer.style.display = filterSelect.value === "@ExploreFilterOptions.ByUser" ? "block" : "none";
            }

            chips.forEach(chip => {
                chip.addEventListener("click", () => {
                    if (!filterSelect) return;
                    filterSelect.value = chip.dataset.filterValue || filterSelect.value;
                    chips.forEach(x => x.classList.remove("is-active"));
                    chip.classList.add("is-active");
                    toggleUsernameField();
                });
            });

            toggleUsernameField();
            filterSelect?.addEventListener("change", () => {
                chips.forEach(x => x.classList.toggle("is-active", x.dataset.filterValue === filterSelect.value));
                toggleUsernameField();
            });
        })();
    </script>
}
