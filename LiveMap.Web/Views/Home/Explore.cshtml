@model LiveMap.Web.Models.Home.ExploreFeedViewModel
@{
    ViewData["Title"] = "Explore";
}

<section class="mb-4">
    <p class="section-eyebrow">Explore</p>
    <h1 class="section-title">Newest public pictures</h1>
    <p class="text-muted">Browse the latest uploaded public images and open the creator profiles.</p>
</section>

@if (Model.Pictures.Any())
{
    <div class="row g-4">
        @foreach (var picture in Model.Pictures)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 shadow-sm">
                   <img src="@picture.ImageUrl" class="card-img-top explore-image" alt="@picture.FolderName image" />
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <img src="@(string.IsNullOrWhiteSpace(picture.ProfilePicture) ? "/images/default.jpeg" : picture.ProfilePicture)"
                                 alt="@picture.Username avatar"
                                 class="rounded-circle"
                                 style="width: 52px; height: 52px; object-fit: cover;" />
                            <div>
                                <div class="fw-semibold">@picture.Username</div>
                                <div class="text-muted small">Folder: @picture.FolderName</div>
                                <div class="text-muted small">@picture.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                            </div>
                        </div>
                        <a asp-controller="Profile" asp-action="Details" asp-route-id="@picture.ProfileId" class="btn btn-outline-primary">Open profile</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">No public pictures have been uploaded yet.</div>
}
