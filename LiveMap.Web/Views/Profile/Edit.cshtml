@model LiveMap.Core.DTOs.Profiles.ProfileEditDto
@{
    ViewData["Title"] = "Edit Profile";
    var previewImage = string.IsNullOrWhiteSpace(Model.ProfilePicture) ? "/images/default.jpeg" : Model.ProfilePicture;
}

<section class="profile-edit-page">
    <div class="profile-edit-shell">
        <div class="profile-edit-intro">
            <div class="profile-edit-floating-badge"><span></span> Profile studio</div>
            <div class="profile-edit-orbit one"></div>
            <div class="profile-edit-orbit two"></div>

            <p class="section-eyebrow">Personalize your account</p>
            <h1 class="profile-title">Give your profile a main character glow-up</h1>
            <p class="profile-edit-lead">Refresh your identity, sharpen your vibe and make your profile look polished, memorable and instantly recognizable.</p>

            <div class="profile-edit-preview-card">
                <img src="@previewImage" alt="Profile preview" class="profile-edit-preview-image" id="profilePreviewImage" />
                <div>
                    <p class="profile-preview-label">Current username</p>
                    <h2 class="profile-preview-name" id="profilePreviewName">@Model.Username</h2>
                    <p class="profile-preview-bio" id="profilePreviewBio">@(string.IsNullOrWhiteSpace(Model.Bio) ? "Add a short bio so people can know more about you." : Model.Bio)</p>

                    <div class="profile-preview-meta">
                        <div class="profile-preview-pill">Elegant</div>
                        <div class="profile-preview-pill">Creative</div>
                        <div class="profile-preview-pill">Travel-ready</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="profile-edit-card">
            <div class="profile-edit-topbar">
                <div>
                    <p class="section-eyebrow mb-0">Edit profile</p>
                    <h2 class="mb-0">Refine every detail</h2>
                    <p>Keep the same functionality, just make your identity feel more premium.</p>
                </div>
                <div class="profile-edit-progress">
                    <strong>100% you</strong>
                    <span>Custom profile panel</span>
                </div>
            </div>

            <form asp-action="Edit" method="post" enctype="multipart/form-data" class="profile-edit-form">
                <input asp-for="Id" type="hidden" />
                <input asp-for="ProfilePicture" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                <div class="profile-form-grid">
                    <div class="profile-form-field">
                        <div class="profile-form-card">
                            <label asp-for="Username" class="profile-form-label">
                                <span class="profile-form-icon">✦</span>
                                Username
                            </label>
                            <input asp-for="Username" class="form-control profile-form-input" placeholder="Enter username" id="profileUsernameInput" />
                            <span asp-validation-for="Username" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="profile-form-field">
                        <div class="profile-form-card">
                            <label class="profile-form-label">
                                <span class="profile-form-icon">🖼</span>
                                Profile picture
                            </label>

                            <div class="profile-upload-zone">
                                <img src="@previewImage" alt="Current profile picture" class="profile-upload-avatar" id="profileUploadThumb" />
                                <div class="profile-upload-copy">
                                    <h3>Upload a sharper photo</h3>
                                    <p>Use a clear image to make your profile card feel cleaner and more professional.</p>
                                </div>
                            </div>

                            <input type="file" name="imageFile" accept="image/*" class="form-control profile-form-input mt-3" id="profileImageInput" />
                            <p class="profile-field-hint">Best result: bright photo, centered face and clean background.</p>
                        </div>
                    </div>

                    <div class="profile-form-field is-full">
                        <div class="profile-form-card">
                            <label asp-for="Bio" class="profile-form-label">
                                <span class="profile-form-icon">✎</span>
                                Bio
                            </label>
                            <textarea asp-for="Bio" class="form-control profile-form-textarea" rows="6" placeholder="Tell people a little about yourself..." id="profileBioInput"></textarea>
                            <span asp-validation-for="Bio" class="text-danger small"></span>
                            <p class="profile-field-hint">Make it short, stylish and memorable. A confident one-liner works great.</p>
                        </div>
                    </div>
                </div>

                <div class="profile-edit-actions">
                    <div>
                        <div class="profile-quick-note">Your current profile data stays intact. You are only updating the visual content here.</div>
                    </div>
                    <div class="profile-edit-actions-left">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary profile-main-button">Save Changes</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const usernameInput = document.getElementById('profileUsernameInput');
            const bioInput = document.getElementById('profileBioInput');
            const imageInput = document.getElementById('profileImageInput');
            const previewName = document.getElementById('profilePreviewName');
            const previewBio = document.getElementById('profilePreviewBio');
            const previewImage = document.getElementById('profilePreviewImage');
            const uploadThumb = document.getElementById('profileUploadThumb');

            if (usernameInput && previewName) {
                usernameInput.addEventListener('input', () => {
                    const value = usernameInput.value.trim();
                    previewName.textContent = value || 'Your username';
                });
            }

            if (bioInput && previewBio) {
                bioInput.addEventListener('input', () => {
                    const value = bioInput.value.trim();
                    previewBio.textContent = value || 'Add a short bio so people can know more about you.';
                });
            }

            if (imageInput && previewImage && uploadThumb) {
                imageInput.addEventListener('change', () => {
                    const [file] = imageInput.files || [];
                    if (!file) return;
                    const url = URL.createObjectURL(file);
                    previewImage.src = url;
                    uploadThumb.src = url;
                });
            }
        })();
    </script>
}
