@model LiveMap.Web.Models.Profile.ProfileViewModel
@{
    var isPublicProfile = !Model.IsOwnProfile;
    ViewData["Title"] = isPublicProfile ? $"{Model.Username} Profile" : "My Profile";
}

<section class="profile-page">
    <div class="profile-header-card">
        <img src="@(string.IsNullOrWhiteSpace(Model.ProfilePicture) ? "/images/default.jpeg" : Model.ProfilePicture)"
             alt="@Model.Username profile picture"
             class="profile-avatar-large" />

        <div>
            <p class="profile-eyebrow">@(isPublicProfile ? "Creator profile" : "Your profile")</p>
            <h1 class="profile-title">@Model.Username</h1>
            <p class="profile-bio">@(string.IsNullOrWhiteSpace(Model.Bio) ? "No bio added yet." : Model.Bio)</p>

            <div class="d-flex flex-wrap gap-3 mb-3">
                <span class="badge text-bg-light p-2">Followers: @Model.FollowersCount</span>
                <span class="badge text-bg-light p-2">Following: @Model.FollowingCount</span>
                <span class="badge text-bg-light p-2">Friends: @Model.FriendsCount</span>
            </div>

            @if (Model.IsOwnProfile)
            {
                <a asp-action="Edit" class="btn btn-primary">Edit Profile</a>
            }
            else if (User.Identity?.IsAuthenticated ?? false)
            {
                if (Model.IsFollowedByCurrentUser)
                {
                    <form asp-action="Unfollow" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger">Unfollow</button>
                    </form>
                }
                else
                {
                    <form asp-action="Follow" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">Follow</button>
                    </form>
                }
            }
        </div>
    </div>


    <div class="section-heading-row d-flex justify-content-between align-items-center">
        <div>
            <p class="section-eyebrow">Folders</p>
            <h2 class="section-title">@(isPublicProfile ? "Visible folders" : "My folders")</h2>
        </div>

        @if (Model.IsOwnProfile)
        {
            <a asp-controller="Folder"
               asp-action="Create"
               class="btn btn-success">
                Create folder
            </a>
        }
    </div>

        @if (Model.Folders != null && Model.Folders.Any())
        {
            <div class="folder-shortcut-grid">
                @foreach (var folder in Model.Folders)
                {
                    <a asp-controller="Folder"
                       asp-action="Details"
                       asp-route-id="@folder.Id"
                       class="folder-shortcut-link"
                       aria-label="Open @folder.Name folder">
                        <span class="folder-shortcut-icon" aria-hidden="true">
                            <svg viewBox="0 0 64 52" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M4 13.5C4 9.35786 7.35786 6 11.5 6H24L29 12H52.5C56.6421 12 60 15.3579 60 19.5V40.5C60 44.6421 56.6421 48 52.5 48H11.5C7.35786 48 4 44.6421 4 40.5V13.5Z" fill="#FFD86B" />
                                <path d="M4 18C4 14.6863 6.68629 12 10 12H54C57.3137 12 60 14.6863 60 18V40C60 44.4183 56.4183 48 52 48H12C7.58172 48 4 44.4183 4 40V18Z" fill="#F4B942" />
                                <path d="M11 19H53" stroke="#D89A19" stroke-width="2.5" stroke-linecap="round" />
                            </svg>
                        </span>
                        <span class="folder-shortcut-name">@folder.Name</span>
                        <span class="badge text-bg-light mt-2">@folder.AccessibilityLabel</span>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="empty-state-card">
                <p>@(isPublicProfile ? "This creator does not have any visible folders yet." : "You have no folders yet.")</p>
            </div>
        }
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
