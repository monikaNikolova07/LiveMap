@model LiveMap.Web.Models.Profile.ProfileViewModel
@{
    var isPublicProfile = !Model.IsOwnProfile;
    ViewData["Title"] = Model.IsAdminProfile ? "Admin Profile" : (isPublicProfile ? $"{Model.Username} Profile" : "My Profile");
}

<section class="profile-page profile-showcase-page">
    <div class="profile-showcase-hero @(Model.IsAdminProfile ? "profile-admin-hero" : string.Empty)">
        <div class="profile-showcase-copy">
            <div class="profile-avatar-shell">
                <img src="@(string.IsNullOrWhiteSpace(Model.ProfilePicture) ? "/images/default.jpeg" : Model.ProfilePicture)"
                     alt="@Model.Username profile picture"
                     class="profile-avatar-large" />
                <span class="profile-avatar-ring"></span>
            </div>

            <div class="profile-showcase-heading">
                <p class="profile-eyebrow">@(Model.IsAdminProfile ? "Protected administrator account" : (isPublicProfile ? "Creator profile" : "Your personal space"))</p>
                <h1 class="profile-title profile-showcase-title">@Model.Username</h1>
                <p class="profile-bio profile-showcase-bio">
                    @(string.IsNullOrWhiteSpace(Model.Bio)
                        ? (Model.IsAdminProfile ? "This account manages the platform and stays hidden from the public side of LiveMap." : "No bio added yet.")
                        : Model.Bio)
                </p>
            </div>

            <div class="profile-showcase-actions">
                @if (Model.IsAdminProfile)
                {
                    <a asp-controller="Admin" asp-action="Index" class="btn btn-primary profile-main-cta">Open admin panel</a>
                }
                else if (Model.IsOwnProfile)
                {
                    <a asp-action="Edit" class="btn btn-primary profile-main-cta">Edit Profile</a>
                }
                else if ((User.Identity?.IsAuthenticated ?? false) && !User.IsInRole("Admin"))
                {
                    if (Model.IsFollowedByCurrentUser)
                    {
                        <form asp-action="Unfollow" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger profile-main-cta">Unfollow</button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Follow" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary profile-main-cta">Follow</button>
                        </form>
                    }
                }
            </div>
        </div>

        <div class="profile-showcase-panel">
            <div class="profile-panel-badge">@(Model.IsAdminProfile ? "Admin mode" : "Live identity")</div>

            @if (Model.IsAdminProfile)
            {
                <div class="admin-profile-note-grid">
                    <div class="profile-mini-story-card">
                        <span>Visibility</span>
                        <strong>Hidden</strong>
                        <small>other users cannot open this profile</small>
                    </div>
                    <div class="profile-mini-story-card is-soft">
                        <span>Social actions</span>
                        <strong>Disabled</strong>
                        <small>no follow, followers or folders</small>
                    </div>
                </div>
            }
            else
            {
                <div class="profile-stats-grid profile-stats-grid-showcase">
                    <a asp-action="Connections" asp-route-id="@Model.Id" asp-route-type="followers" class="profile-stat-card profile-stat-card-link text-decoration-none">
                        <div class="profile-stat-label">Followers</div>
                        <div class="profile-stat-value">@Model.FollowersCount</div>
                    </a>
                    <a asp-action="Connections" asp-route-id="@Model.Id" asp-route-type="following" class="profile-stat-card profile-stat-card-link text-decoration-none">
                        <div class="profile-stat-label">Following</div>
                        <div class="profile-stat-value">@Model.FollowingCount</div>
                    </a>
                    <a asp-action="Connections" asp-route-id="@Model.Id" asp-route-type="friends" class="profile-stat-card profile-stat-card-link text-decoration-none">
                        <div class="profile-stat-label">Friends</div>
                        <div class="profile-stat-value">@Model.FriendsCount</div>
                    </a>
                </div>

                <div class="profile-mini-storyboard">
                    <div class="profile-mini-story-card">
                        <span>Folders</span>
                        <strong>@(Model.Folders?.Count ?? 0)</strong>
                        <small>collections ready to open</small>
                    </div>
                    <div class="profile-mini-story-card is-soft">
                        <span>Presence</span>
                        <strong>@(isPublicProfile ? "Public" : "Owner")</strong>
                        <small>@(isPublicProfile ? "creator view" : "editing mode")</small>
                    </div>
                </div>
            }
        </div>

        <div class="profile-hero-orb one"></div>
        <div class="profile-hero-orb two"></div>
    </div>

    <div class="section-heading-row profile-folders-topbar">
        <div>
            <p class="section-eyebrow">@(Model.IsAdminProfile ? "Control center" : "Folder universe")</p>
            <h2 class="section-title">@(Model.IsAdminProfile ? "Administrator tools" : (isPublicProfile ? "Visible folders" : "My folders"))</h2>
        </div>

        @if (Model.IsOwnProfile && !Model.IsAdminProfile)
        {
            <a asp-controller="Folder" asp-action="Create" class="btn btn-success">Create folder</a>
        }
    </div>

    @if (Model.IsAdminProfile)
    {
        <div class="empty-state-card admin-profile-special-card">
            <h3>Administrator profile is intentionally separate from the public travel space.</h3>
            <p class="mb-3">This account can access moderation and management tools, but it cannot follow users, be followed, or build public folder galleries.</p>
            <a asp-controller="Admin" asp-action="Index" class="btn btn-primary">Go to admin dashboard</a>
        </div>
    }
    else if (Model.Folders != null && Model.Folders.Any())
    {
        <div class="folder-shortcut-grid profile-folder-grid-upgraded profile-folder-simple-grid">
            @foreach (var folder in Model.Folders)
            {
                <article class="folder-showcase-card folder-simple-card">
                    @if (Model.IsOwnProfile)
                    {
                        <div class="folder-card-actions">
                            <a asp-controller="Folder"
                               asp-action="Edit"
                               asp-route-id="@folder.Id"
                               class="folder-action-button folder-action-button-edit"
                               title="Edit folder"
                               aria-label="Edit @folder.Name">✎</a>

                            <form asp-controller="Folder" asp-action="Delete" method="post" class="folder-delete-form" onsubmit="return confirm('Are you sure you want to delete this folder?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@folder.Id" />
                                <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Profile", new { id = Model.Id })" />
                                <button type="submit" class="folder-action-button folder-action-button-delete" title="Delete folder" aria-label="Delete @folder.Name">×</button>
                            </form>
                        </div>
                    }

                    <a asp-controller="Folder" asp-action="Details" asp-route-id="@folder.Id" class="folder-shortcut-link folder-showcase-link folder-simple-link" aria-label="Open @folder.Name folder">
                        <div class="folder-simple-center">
                            <span class="folder-simple-icon" aria-hidden="true">📁</span>
                            <div class="folder-showcase-body folder-showcase-body-centered">
                                <span class="folder-shortcut-name folder-shortcut-name-simple">@folder.Name</span>
                            </div>
                        </div>
                    </a>
                </article>
            }
        </div>
    }
    else
    {
        <div class="empty-state-card"> <p>@(isPublicProfile ? "This creator does not have any visible folders yet." : "You have no folders yet.")</p> </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
