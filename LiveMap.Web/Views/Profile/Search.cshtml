@model LiveMap.Web.Models.Profile.ProfileSearchPageViewModel
@{
    ViewData["Title"] = "Search users";
}

<section class="mb-4">
    <p class="section-eyebrow">Community</p>
    <h1 class="section-title">Search users</h1>
    <form method="get" class="row g-2 mt-2">
        <div class="col-md-8">
            <input type="text" name="term" value="@Model.Term" class="form-control" placeholder="Search by username..." />
        </div>
        <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </form>
</section>

@if (Model.Results.Any())
{
    <div class="row g-3">
        @foreach (var user in Model.Results)
        {
            <div class="col-md-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex gap-3">
                        <img src="@(string.IsNullOrWhiteSpace(user.ProfilePicture) ? "/images/default.jpeg" : user.ProfilePicture)"
                             alt="@user.Username avatar"
                             class="rounded-circle"
                             style="width: 72px; height: 72px; object-fit: cover;" />
                        <div class="flex-grow-1">
                            <h5 class="mb-1">@user.Username</h5>
                            <p class="text-muted mb-2">@(string.IsNullOrWhiteSpace(user.Bio) ? "No bio yet." : user.Bio)</p>
                            <div class="small text-muted mb-3">Followers: @user.FollowersCount</div>
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-outline-primary btn-sm">Open profile</a>
                                @if ((User.Identity?.IsAuthenticated ?? false) && !user.IsOwnProfile)
                                {
                                    @if (user.IsFollowedByCurrentUser)
                                    {
                                        <form asp-action="Unfollow" asp-route-id="@user.Id" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm">Unfollow</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Follow" asp-route-id="@user.Id" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-primary btn-sm">Follow</button>
                                        </form>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">No users matched your search.</div>
}
