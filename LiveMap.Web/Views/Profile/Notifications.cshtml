@model LiveMap.Web.Models.Profile.NotificationsViewModel
@{
    ViewData["Title"] = "Notifications";
}

<section class="notifications-shell">
    <div class="notifications-hero">
        <div>
            <p class="section-eyebrow">Notifications</p>
            <h1 class="section-title notifications-title">Fresh activity around your profile</h1>
            <p class="text-muted mb-0">A softer, cleaner timeline for new followers without making the page too busy.</p>
        </div>
        <div class="notifications-counter-card">
            <span>New followers</span>
            <strong>@Model.Followers.Count()</strong>
            <small>latest updates</small>
        </div>
    </div>

    @if (Model.Followers.Any())
    {
        <div class="notifications-stack">
            @foreach (var item in Model.Followers)
            {
                <a asp-action="Details" asp-route-id="@item.ProfileId" class="notifications-card">
                    <div class="notifications-avatar-wrap">
                        <img src="@(string.IsNullOrWhiteSpace(item.ProfilePicture) ? "/images/default.jpeg" : item.ProfilePicture)"
                             alt="@item.Username avatar"
                             class="notifications-avatar" />
                        <span class="notifications-avatar-dot"></span>
                    </div>

                    <div class="notifications-content">
                        <div class="notifications-topline">
                            <strong>@item.Username</strong>
                            <span class="notifications-time">@item.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                        <p class="notifications-text">started following you and is now part of your activity feed.</p>
                    </div>

                    <span class="notifications-arrow">↗</span>
                </a>
            }
        </div>
    }
    else
    {
        <div class="empty-state-card">
            <h3>No notifications yet</h3>
            <p class="mb-0">When someone follows you, the update will appear here.</p>
        </div>
    }
</section>
