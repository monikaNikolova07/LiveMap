@using LiveMap.Data.Models
@model LiveMap.Core.DTOs.Folders.FolderCreateDto

<h2>Create Folder</h2>

<form asp-action="Create" method="post">

    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label"></label>

        <select asp-for="Name" asp-items="ViewBag.Countries" class="form-control">
            <option value="">-- Select country --</option>
        </select>

        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Acssesability" class="form-label"></label>

        <select asp-for="Acssesability"
                asp-items="Html.GetEnumSelectList<Acssesability>()"
                class="form-control">
            <option value="">-- Select access --</option>
        </select>

        <span asp-validation-for="Acssesability" class="text-danger"></span>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}