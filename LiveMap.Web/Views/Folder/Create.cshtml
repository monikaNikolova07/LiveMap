@model LiveMap.Web.Models.Folder.FolderCreateViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

<h2>Create Folder</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="Name">Choice country (folder name)</label>
        <select asp-for="Name" class="form-control" asp-items="@(new SelectList(ViewBag.Countries, "Value", "Text"))">
            <option value="">-- Select Country --</option>
        </select>
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-2">Create Folder</button>
</form>