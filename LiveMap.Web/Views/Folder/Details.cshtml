@model LiveMap.Web.Models.Folder.FolderDetailsViewModel

@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1">@Model.Name</h2>
        <p class="text-muted mb-0">Accessibility: @(Model.Acssesability == LiveMap.Data.Models.Acssesability.FriendsOnly ? "Friends Only" : Model.Acssesability.ToString())</p>
    </div>
</div>

@if (Model.IsOwner)
{
    <div class="d-flex flex-wrap gap-2 mb-4">
        <a asp-action="Upload" asp-route-folderId="@Model.Id" class="btn btn-success">Add picture</a>
        <a asp-action="CreateSubfolder" asp-route-parentFolderId="@Model.Id" class="btn btn-primary">Create folder in this folder</a>
    </div>
}

<div class="mb-4">
    <h3>Subfolders</h3>
    @if (Model.Subfolders.Any())
    {
        <div class="folder-shortcut-grid">
            @foreach (var folder in Model.Subfolders)
            {
                <div class="folder-shortcut-card">
                    @if (Model.IsOwner)
                    {
                        <form asp-action="Delete" method="post" class="folder-delete-form" onsubmit="return confirm('Are you sure you want to delete this folder?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@folder.Id" />
                            <input type="hidden" name="returnUrl" value="@Url.Action("Details", "Folder", new { id = Model.Id })" />
                            <button type="submit" class="folder-delete-button" title="Delete folder" aria-label="Delete @folder.Name">×</button>
                        </form>
                    }

                    <a asp-action="Details"
                       asp-route-id="@folder.Id"
                       class="folder-shortcut-link"
                       aria-label="Open @folder.Name folder">
                        <span class="folder-shortcut-icon" aria-hidden="true">
                            <svg viewBox="0 0 64 52" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M4 13.5C4 9.35786 7.35786 6 11.5 6H24L29 12H52.5C56.6421 12 60 15.3579 60 19.5V40.5C60 44.6421 56.6421 48 52.5 48H11.5C7.35786 48 4 44.6421 4 40.5V13.5Z" fill="#FFD86B" />
                                <path d="M4 18C4 14.6863 6.68629 12 10 12H54C57.3137 12 60 14.6863 60 18V40C60 44.4183 56.4183 48 52 48H12C7.58172 48 4 44.4183 4 40V18Z" fill="#F4B942" />
                                <path d="M11 19H53" stroke="#D89A19" stroke-width="2.5" stroke-linecap="round" />
                            </svg>
                        </span>

                        <span class="folder-shortcut-name">@folder.Name</span>

                        <span class="badge text-bg-light mt-2">
                            @(folder.Acssesability == LiveMap.Data.Models.Acssesability.FriendsOnly ? "Friends Only" : folder.Acssesability.ToString())
                        </span>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No subfolders yet.</p>
    }
</div>

<div>
    <h3>Pictures</h3>
    @if (Model.Pictures.Any())
    {
        <div class="row g-3">
            @foreach (var pic in Model.Pictures)
            {
                <div class="col-md-3 col-sm-4 col-6">
                    <div class="picture-card">
                        @if (Model.IsOwner)
                        {
                            <div class="picture-card-actions">
                                <a asp-controller="Picture"
                                   asp-action="EditVisibility"
                                   asp-route-id="@pic.Id"
                                   class="picture-action-button picture-action-button-edit"
                                   title="Edit picture visibility"
                                   aria-label="Edit visibility for picture">✎</a>

                                <form asp-controller="Picture" asp-action="Delete" method="post" class="picture-delete-form" onsubmit="return confirm('Are you sure you want to delete this picture?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@pic.Id" />
                                    <input type="hidden" name="folderId" value="@Model.Id" />
                                    <button type="submit" class="picture-action-button picture-action-button-delete" title="Delete picture" aria-label="Delete picture">×</button>
                                </form>
                            </div>
                        }

                        <img src="@pic.Url" class="picture-card-image" alt="Folder picture" />
                        <div class="picture-card-body">
                            <small class="text-muted">@(pic.Acssesability == LiveMap.Data.Models.Acssesability.FriendsOnly ? "Friends Only" : pic.Acssesability.ToString())</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No pictures uploaded yet.</p>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
