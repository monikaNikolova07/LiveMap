@using LiveMap.Data.Models
@model IEnumerable<LiveMap.Web.Models.Folder.FolderViewModel>

<h2>Folders</h2>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var folder in Model)
        {
            <tr>
                <td>@folder.Name</td>
                <td>
                    <a asp-action="Details" asp-route-id="@folder.Id" class="btn btn-primary">
                        View All Pictures
                    </a>
                    <a asp-action="Upload" asp-route-folderId="@folder.Id" class="btn btn-success">
                        Upload
                    </a>
                    <a asp-action="Delete" asp-route-id="@folder.Id" class="btn btn-danger">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Create" class="btn btn-primary">Create Folder</a>
